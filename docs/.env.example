database_url=sqlite:///./contacts.db # Database URL for SQLite. For example, you can use "sqlite:///./contacts.db" to create a local SQLite database file named "contacts.db" in the current directory.
# For PostgreSQL, you can use a URL like "postgresql://user:password@localhost:5432/mydatabase". Make sure to replace "user", "password", "localhost", "5432", and "mydatabase" with your actual PostgreSQL credentials and database name.
# If you want to use environment variables for PostgreSQL, you can set the following variables and then construct the database URL in your application code:
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=your_db_host
# DB_PORT=your_db_port
# DB_NAME=your_db_name  